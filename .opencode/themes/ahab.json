      "dark": "foam",
      "light": "foam"
    },
    "syntaxFunction": {
      "dark": "compass",
      "light": "compass"
    },
    "syntaxVariable": {
      "dark": "crest",
      "light": "abyss"
    },
    "syntaxString": {
      "dark": "seafoam",
      "light": "kelp"
    },
    "syntaxNumber": {
      "dark": "pearl",
      "light": "barnacle"
    },
    "syntaxType": {
      "dark": "starboard",
      "light": "compass"
    },
    "syntaxOperator": {
      "dark": "foam",
      "light": "foam"
    },
    "syntaxPunctuation": {
