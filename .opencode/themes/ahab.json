{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "abyss": "#080e14",
    "deep": "#0d1620",
    "midnight": "#111d2b",
    "ocean": "#162636",
    "current": "#1b3045",
    "spray": "#2a4560",
    "foam": "#3d5e7a",
    "mist": "#5a7894",
    "hull": "#7d96ae",
    "sail": "#a3b8cc",
    "crest": "#c8d6e5",
    "whitecap": "#e0e8f0",
    "harpoon": "#c0392b",
    "whale": "#e74c3c",
    "blood": "#8b1a1a",
    "compass": "#3498db",
    "starboard": "#5dade2",
    "lantern": "#f4d03f",
    "amber": "#e6a817",
    "kelp": "#27ae60",
    "seafoam": "#2ecc71",
    "coral": "#e67e22",
    "barnacle": "#7d5a9a",
    "pearl": "#bb8fce",
